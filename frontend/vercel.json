{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.geovision.risetmaster.my.id/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "https://api.geovision.risetmaster.my.id/storage/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
